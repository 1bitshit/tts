# =============================================================================
# Qwen3-TTS Server Configuration
# =============================================================================

# Model Configuration
QWEN_TTS_CUSTOM_VOICE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN_TTS_VOICE_DESIGN_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
QWEN_TTS_BASE_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-Base
QWEN_TTS_TOKENIZER=Qwen/Qwen3-TTS-Tokenizer-12Hz

# Device Configuration
# For GPU:
# CUDA_DEVICE=cuda:0
# For CPU:
# CUDA_DEVICE=cpu
CUDA_DEVICE=cuda:0
MODEL_DTYPE=bfloat16
# Note: Flash Attention IS INCLUDED in the Docker image.
# For local dev, install manually: pip install flash-attn>=2.5.0 --no-build-isolation
USE_FLASH_ATTENTION=true

# Pure-C Qwen3-TTS engine (default). Run setup/tts-engine.sh install/start.
TTS_ENGINE=rust-server
C_TTS_URL=http://127.0.0.1:8030
RUST_TTS_LISTEN=127.0.0.1:8030
RUST_TTS_UPSTREAM=http://127.0.0.1:8020
RUST_TTS_MAX_CONCURRENT=1
RUST_TTS_CONNECT_TIMEOUT_SECONDS=5
RUST_TTS_REQUEST_TIMEOUT_SECONDS=600
C_TTS_TIMEOUT_SECONDS=600

# API Configuration, empty means no authentication
API_KEYS=
HOST=0.0.0.0
PORT=8000

# LM Studio / llmster
# LM Studio itself remains local-only; the authenticated proxy is exposed.
LM_STUDIO_INTERNAL_HOST=127.0.0.1
LM_STUDIO_INTERNAL_PORT=1234
LM_STUDIO_PROXY_HOST=0.0.0.0
LM_STUDIO_PROXY_PORT=1235
# Optional model to download/load during setup (example: openai/gpt-oss-20b)
LM_STUDIO_MODEL=
LM_STUDIO_DOWNLOAD_MODEL=false

# Persistent Debate/Story sessions, RAG memory and model ratings
SESSION_DB_PATH=./data/sessions.sqlite3
DATA_DIR=./data
DEBATE_SETUP_MODELS=Qwen/Qwen3-0.6B-GGUF
STORY_SETUP_MODELS=byteshape/Qwen3-4B-Instruct-2507-GGUF
MODEL_JUDGE_NAME=Qwen/Qwen3-0.6B-GGUF

# Beam public tunnels (credentials stay in .env and are never committed)
BEAM_USERNAME=
BEAM_API_KEY=
BEAM_DOMAIN=beam.eysho.info
BEAM_CONTROL_PORT=8080
BEAM_TTS_REMOTE_PORT=80
BEAM_LMS_REMOTE_PORT=80
BEAM_SSH_ENABLED=false
BEAM_SSH_LOCAL_PORT=22
BEAM_SSH_REMOTE_PORT=22


# Environment Mode (development/production)
# - development: enables /docs, /redoc, /openapi.json
# - production: disables API documentation endpoints
ENV=development

# Model Loading
# Set to true to preload all models on startup (requires more GPU memory)
PRELOAD_MODELS=false

# Model Warmup
# Set to true to run warmup on startup (reduces first request latency)
ENABLE_WARMUP=true
WARMUP_TEXT=This is a warmup test to initialize the model.

# Voice Prompt Caching
VOICE_CACHE_ENABLED=true
VOICE_CACHE_MAX_SIZE=100
VOICE_CACHE_TTL_SECONDS=3600

# Audio Preprocessing
AUDIO_PREPROCESSING_ENABLED=true
REF_AUDIO_MAX_DURATION=15.0
REF_AUDIO_TARGET_DURATION_MIN=5.0

# Audio Upload Validation
AUDIO_UPLOAD_MAX_SIZE_MB=5.0
AUDIO_UPLOAD_MAX_DURATION=60.0

# Performance Logging
ENABLE_PERFORMANCE_LOGGING=true

# Model Caching (HuggingFace cache directory)
# HF_HOME=/path/to/models
# MODEL_CACHE_DIR=/path/to/models

# Logging
LOG_LEVEL=INFO

# SSL/HTTPS (optional)
# SSL_ENABLED=true
# SSL_CERTFILE=./certs/cert.pem
# SSL_KEYFILE=./certs/key.pem

# Story author/editor pipeline. Models are loaded sequentially to limit VRAM use.
STORY_AUTHOR_MODEL=Qwen/Qwen3-14B-GGUF
STORY_EDITOR_MODEL=bartowski/Mistral-Small-24B-Instruct-2501-GGUF
STORY_MODEL_SWITCHING=true
STORY_AUTHOR_QUANT=Q4_K_M
STORY_EDITOR_QUANT=Q4_K_M
STORY_AUTHOR_GPU_OFFLOAD=max
STORY_EDITOR_GPU_OFFLOAD=0.65
STORY_MODEL_CONTEXT=32768
STORY_MODEL_TTL_SECONDS=180
